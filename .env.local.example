# Convex — se completan automáticamente al correr `npx convex dev`
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=

# URL HTTP del deployment de Convex (ej: https://xxx.convex.site)
VITE_CONVEX_SITE_URL=

# URL pública del frontend
SITE_URL=http://localhost:3000

# Secreto de Better Auth — generar con: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Redirect URI autorizado: ${VITE_CONVEX_SITE_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
